<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_credit_notes" model="ir.actions.report">
        <field name="name">Notas de Crédito con Motivo</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">iia_ventas_restricciones.report_credit_notes_doc</field>
        <field name="report_file">iia_ventas_restricciones.report_credit_notes_doc</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
    </record>

    <template id="report_credit_notes_doc">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <h2>Notas de Crédito con Motivo</h2>
                    <table class="table table-sm mt-4">
                        <thead>
                            <tr>
                                <th>Número</th>
                                <th>Fecha</th>
                                <th>Cliente</th>
                                <th>Motivo</th>
                                <th class="text-right">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="docs" t-as="doc">
                                <tr t-if="doc.move_type in ('out_refund', 'in_refund')">
                                    <td><span t-field="doc.name"/></td>
                                    <td><span t-field="doc.invoice_date"/></td>
                                    <td><span t-field="doc.partner_id"/></td>
                                    <td>
                                        <t t-if="doc.credit_note_reason">
                                            <span t-field="doc.credit_note_reason"/>
                                        </t>
                                        <t t-elif="doc.ref">
                                            <span t-field="doc.ref"/>
                                        </t>
                                        <t t-else="">
                                            <em>Sin motivo</em>
                                        </t>
                                    </td>
                                    <td class="text-right"><span t-field="doc.amount_total"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>

    <record id="action_credit_notes_window" model="ir.actions.act_window">
        <field name="name">Notas de Crédito</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('move_type', 'in', ['out_refund', 'in_refund'])]</field>
        <field name="context">{'default_move_type': 'out_refund'}</field>
    </record>

    <menuitem id="menu_credit_notes"
              name="Notas de Crédito"
              parent="menu_iia_restricciones_root"
              action="action_credit_notes_window"
              sequence="20"/>
</odoo>
