<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cancel_invoice_wizard_form" model="ir.ui.view">
        <field name="name">cancel.invoice.wizard.form</field>
        <field name="model">cancel.invoice.wizard</field>
        <field name="arch" type="xml">
            <form string="Cancelar Factura">
                <sheet>
                    <group>
                        <field name="invoice_ids" widget="many2many_tags" readonly="1"/>
                        <field name="reason" placeholder="Ingrese el motivo de cancelación..."/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_cancel" string="Cancelar Factura" type="object" class="btn-danger"/>
                    <button string="Descartar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
